[{"id": 38497, "title": "Amid launch bottleneck, Amazon has \"hundreds\" of satellites waiting to fly", "authors": [{"name": "Eric Berger", "socials": null}], "url": "https://arstechnica.com/space/2026/06/amid-launch-bottleneck-amazon-has-hundreds-of-satellites-waiting-to-fly/", "image_url": "https://cdn.arstechnica.net/wp-content/uploads/2026/06/amazon-leo.jpg", "news_site": "Arstechnica", "summary": "\"As for Arianespace, they have definitely stepped up.\"", "published_at": "2026-06-16T21:14:08Z", "updated_at": "2026-06-17T06:51:33.183262Z", "featured": false, "launches": [{"launch_id": "9eb09815-c237-4fdd-9057-5b161131240c", "provider": "Launch Library 2"}, {"launch_id": "ca3d56b7-2175-48e4-9a6a-2ecc9996d96b", "provider": "Launch Library 2"}, {"launch_id": "ed8ccd18-b530-4f55-92ae-bda89ac2985c", "provider": "Launch Library 2"}, {"launch_id": "ef9850ad-1096-425b-9d27-f7bbd186e61a", "provider": "Launch Library 2"}], "events": []}, {"id": 38494, "title": "Arianespace CEO Says Strike Will Not Affect Ariane 6 Launch", "authors": [{"name": "European Spaceflight", "socials": null}], "url": "https://europeanspaceflight.com/arianespace-ceo-says-strike-will-not-affect-ariane-6-launch/", "image_url": "https://europeanspaceflight.com/wp-content/uploads/2026/06/Arianespace-CEO-Says-Strike-Will-Not-Affect-Ariane-6-Launch.webp", "news_site": "European Spaceflight", "summary": "A strike that saw entrances to the Guiana Space Centre barricaded has ended, with Arianespace CEO David Cavaillol\u00e8s saying the labour dispute has not affected tomorrow\u2019s planned Ariane 6 launch from the site. Radio-T\u00e9l\u00e9 P\u00e9yi Guyane reported that the UTG, or Union of Guyanese Workers, had filed an indefinite general strike notice on 14 June, [\u2026]\r\nThe post Arianespace CEO Says Strike Will Not Affect Ariane 6 Launch appeared first on European Spaceflight.", "published_at": "2026-06-16T18:24:56Z", "updated_at": "2026-06-17T06:48:51.788215Z", "featured": false, "launches": [{"launch_id": "ed8ccd18-b530-4f55-92ae-bda89ac2985c", "provider": "Launch Library 2"}], "events": []}, {"id": 38455, "title": "Watch live: bigger booster, more powerful Ariane 6 launch", "authors": [{"name": "ESA", "socials": null}], "url": "https://www.esa.int/Enabling_Support/Space_Transportation/Ariane/Watch_live_bigger_booster_more_powerful_Ariane_6_launch", "image_url": "https://www.esa.int/var/esa/storage/images/esa_multimedia/images/2026/05/p160c_based_booster_for_ariane_6_arrives_at_the_launch_pad/27310691-1-eng-GB/P160C_based_booster_for_Ariane_6_arrives_at_the_launch_pad_card_full.jpg", "news_site": "ESA", "summary": "From the ESA Blogs.", "published_at": "2026-06-15T12:10:00Z", "updated_at": "2026-06-15T14:20:51.414561Z", "featured": false, "launches": [{"launch_id": "ed8ccd18-b530-4f55-92ae-bda89ac2985c", "provider": "Launch Library 2"}], "events": []}, {"id": 38437, "title": "Rocket Report: Nova moving through test campaign; SpaceX IPO launches Friday", "authors": [{"name": "Eric Berger", "socials": null}], "url": "https://arstechnica.com/space/2026/06/rocket-report-nova-moving-through-test-campaign-spacex-ipo-launches-friday/", "image_url": "https://cdn.arstechnica.net/wp-content/uploads/2026/06/stoke-space-2.jpg", "news_site": "Arstechnica", "summary": "\"If I needed to fly on another vehicle, what would that look like?\"", "published_at": "2026-06-12T11:00:13Z", "updated_at": "2026-06-12T13:05:31.696604Z", "featured": false, "launches": [{"launch_id": "ed8ccd18-b530-4f55-92ae-bda89ac2985c", "provider": "Launch Library 2"}, {"launch_id": "8034d81b-af96-460c-a7b7-5c8e7f1a1d86", "provider": "Launch Library 2"}, {"launch_id": "e652a538-6d40-4b55-97a6-7c757ec4e1e9", "provider": "Launch Library 2"}, {"launch_id": "260a062e-ddff-410f-a17a-cc3241a5df47", "provider": "Launch Library 2"}, {"launch_id": "114577dc-7617-461c-aaeb-9bd0f64b5a4b", "provider": "Launch Library 2"}], "events": []}, {"id": 38404, "title": "Same rocket, new boost", "authors": [{"name": "ESA", "socials": null}], "url": "https://www.esa.int/ESA_Multimedia/Videos/2026/06/Same_rocket_new_boost", "image_url": "https://www.esa.int/var/esa/storage/images/esa_multimedia/videos/2026/06/same_rocket_new_boost/27317273-1-eng-GB/Same_rocket_new_boost_card_full.png", "news_site": "ESA", "summary": "The eighth flight of Europe\u2019s rocket Ariane 6 will have a bigger boost: the P120C solid-propellant rocket motor, used as Ariane 6 booster so far, has been upgraded. The new P160C flying on Ariane 6 flight VA269 offers 10% more performance to orbit.", "published_at": "2026-06-11T11:40:00Z", "updated_at": "2026-06-12T07:33:01.886861Z", "featured": false, "launches": [{"launch_id": "ed8ccd18-b530-4f55-92ae-bda89ac2985c", "provider": "Launch Library 2"}], "events": []}, {"id": 38271, "title": "Launch of Most Powerful Ariane 6 to Date Set for 17 June", "authors": [{"name": "European Spaceflight", "socials": null}], "url": "https://europeanspaceflight.com/launch-of-most-powerful-ariane-6-to-date-set-for-17-june/", "image_url": "https://europeanspaceflight.com/wp-content/uploads/2026/06/Launch-of-Most-Powerful-Ariane-6-to-Date-Set-for-17-June.webp", "news_site": "European Spaceflight", "summary": "Arianespace has announced that the first Ariane 64 rocket equipped with its upgraded P160C solid-fuel boosters will be launched on 17 June. The rocket will carry 36 satellites to low Earth orbit for Amazon. Since its introduction in July 2024, a total of seven Ariane 6 flights have been launched from the Guiana Space Centre\u2019s [\u2026]\r\nThe post Launch of Most Powerful Ariane 6 to Date Set for 17 June appeared first on European Spaceflight.", "published_at": "2026-06-05T15:05:25Z", "updated_at": "2026-06-08T06:42:19.089142Z", "featured": false, "launches": [{"launch_id": "ed8ccd18-b530-4f55-92ae-bda89ac2985c", "provider": "Launch Library 2"}], "events": []}, {"id": 38265, "title": "Next Ariane 6 launch to carry 36 Amazon Leo satellites using upgraded boosters", "authors": [{"name": "Jeff Foust", "socials": {"x": "https://x.com/jeff_foust", "youtube": "", "instagram": "", "linkedin": "https://www.linkedin.com/in/jefffoust", "mastodon": "https://mastodon.social/@jfoust", "bluesky": "https://bsky.app/profile/jfoust.bsky.social"}}], "url": "https://spacenews.com/next-ariane-6-launch-to-carry-36-amazon-leo-satellites-using-upgraded-boosters/", "image_url": "https://i0.wp.com/spacenews.com/wp-content/uploads/2026/06/amazonleo-ariane6.jpeg?fit=1024%2C576&ssl=1", "news_site": "SpaceNews", "summary": "Amazon will fly its largest number of broadband satellites to date later this month on the first Ariane 6 launch to use upgraded boosters.\r\nThe post Next Ariane 6 launch to carry 36 Amazon Leo satellites using upgraded boosters appeared first on SpaceNews.", "published_at": "2026-06-05T14:02:31Z", "updated_at": "2026-06-05T14:51:24.143628Z", "featured": false, "launches": [{"launch_id": "ed8ccd18-b530-4f55-92ae-bda89ac2985c", "provider": "Launch Library 2"}], "events": []}, {"id": 38273, "title": "Date is set for bigger booster, more powerful Ariane 6", "authors": [{"name": "ESA", "socials": null}], "url": "https://www.esa.int/Enabling_Support/Space_Transportation/Ariane/Date_is_set_for_bigger_booster_more_powerful_Ariane_6", "image_url": "https://www.esa.int/var/esa/storage/images/esa_multimedia/images/2026/05/p160c_based_booster_for_ariane_6_arrives_at_the_launch_pad/27310691-1-eng-GB/P160C_based_booster_for_Ariane_6_arrives_at_the_launch_pad_card_full.jpg", "news_site": "ESA", "summary": "From the ESA Blogs.", "published_at": "2026-06-05T13:53:00Z", "updated_at": "2026-06-08T06:42:25.779125Z", "featured": false, "launches": [{"launch_id": "ed8ccd18-b530-4f55-92ae-bda89ac2985c", "provider": "Launch Library 2"}], "events": []}, {"id": 37006, "title": "Amazon Leo targets faster deployment cadence as deadline pressure mounts", "authors": [{"name": "Jason Rainbow", "socials": {"x": "", "youtube": "", "instagram": "", "linkedin": "https://www.linkedin.com/in/jasonrainbow", "mastodon": "", "bluesky": ""}}], "url": "https://spacenews.com/amazon-leo-targets-faster-deployment-cadence-as-deadline-pressure-mounts/", "image_url": "https://i0.wp.com/spacenews.com/wp-content/uploads/2026/03/Amazon-stack.jpeg?fit=1024%2C576&ssl=1", "news_site": "SpaceNews", "summary": "Amazon vowed to double the annual launch rate for its low Earth orbit broadband constellation to more than 20 missions, hinging largely on rockets yet to prove themselves at scale.\r\nThe post Amazon Leo targets faster deployment cadence as deadline pressure mounts appeared first on SpaceNews.", "published_at": "2026-03-23T20:39:35Z", "updated_at": "2026-03-24T09:30:50.314909Z", "featured": false, "launches": [{"launch_id": "8a9f7ce9-4ab5-4227-95f1-9f328def8828", "provider": "Launch Library 2"}, {"launch_id": "ed8ccd18-b530-4f55-92ae-bda89ac2985c", "provider": "Launch Library 2"}], "events": []}, {"id": 34970, "title": "Ariane 6 and Vega C P160C Booster Upgrade Fully Qualified", "authors": [{"name": "European Spaceflight", "socials": null}], "url": "https://europeanspaceflight.com/ariane-6-and-vega-c-p160c-booster-upgrade-fully-qualified/", "image_url": "https://europeanspaceflight.com/wp-content/uploads/2025/12/Ariane-6-and-Vega-C-P160C-Booster-Upgrade-Fully-Qualified.webp", "news_site": "European Spaceflight", "summary": "The European Space Agency has completed the qualification review of the P160C solid-fuel booster upgrade for Ariane 6 and Vega C, confirming that it is ready for operational use. The booster is expected to be used for the first time next year aboard an Ariane 6 rocket. In March 2022, ESA announced that it would [\u2026]\r\nThe post Ariane 6 and Vega C P160C Booster Upgrade Fully Qualified appeared first on European Spaceflight.", "published_at": "2025-12-23T05:00:26Z", "updated_at": "2025-12-23T07:01:46.567059Z", "featured": false, "launches": [{"launch_id": "ed8ccd18-b530-4f55-92ae-bda89ac2985c", "provider": "Launch Library 2"}, {"la