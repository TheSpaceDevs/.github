[{"id": 39044, "title": "Week in images: 13-17 July 2026", "authors": [{"name": "ESA", "socials": null}], "url": "https://www.esa.int/About_Us/Week_in_images/Week_in_images_13-17_July_2026", "image_url": "https://www.esa.int/var/esa/storage/images/esa_multimedia/images/2026/07/earth_from_space_guinea-bissau/27381078-2-eng-GB/Earth_from_Space_Guinea-Bissau_card_full.jpg", "news_site": "ESA", "summary": "Week in images: 13-17 July 2026", "published_at": "2026-07-17T13:10:00Z", "updated_at": "2026-07-17T13:10:18.785632Z", "featured": false, "launches": [], "events": []}, {"id": 39045, "title": "SpaceX\u2019s only problem is finding more space to work with", "authors": [{"name": "Anatolii Papulov", "socials": null}], "url": "https://spacenews.com/spacexs-only-problem-is-finding-more-space-to-work-with/", "image_url": "https://i0.wp.com/spacenews.com/wp-content/uploads/2021/04/megaconstellation-coverage-ESA-science-office.jpg?fit=1024%2C761&ssl=1", "news_site": "SpaceNews", "summary": "\nSpaceX\u2019s IPO marks the moment the space dream became a mainstream capital markets story. For decades, it has sold a vision of interplanetary civilization on behalf of the wider space [\u2026]\nThe post SpaceX\u2019s only problem is finding more space to work with appeared first on SpaceNews.", "published_at": "2026-07-17T13:00:00Z", "updated_at": "2026-07-17T13:10:28.384792Z", "featured": false, "launches": [], "events": []}, {"id": 39043, "title": "Rocket Report: India's Vikram-1 nears debut flight; AST to become rocket company?", "authors": [{"name": "Eric Berger", "socials": null}], "url": "https://arstechnica.com/space/2026/07/rocket-report-indias-vikram-1-nears-debut-flight-ast-to-become-rocket-company/", "image_url": "https://cdn.arstechnica.net/wp-content/uploads/2026/07/HNXUiZqWEAEnWu_.jpg", "news_site": "Arstechnica", "summary": "\"We have done everything that could be done to test Vikram-1 on ground.\"", "published_at": "2026-07-17T11:00:04Z", "updated_at": "2026-07-17T11: